# Frontend build-time config (Vite). Copy to `.env` for local dev.
# This is the ONLY frontend env var — no secrets ever live in the frontend.
#
# The base URL of the deployed Worker API. For local dev with `wrangler dev`
# this is usually http://127.0.0.1:8787. In production set it to your Worker
# URL, e.g. https://noha-directory-api.YOUR-SUBDOMAIN.workers.dev
VITE_API_BASE=http://127.0.0.1:8787
