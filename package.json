{
  "name": "noha-directory",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A dignified web app for storing and reciting noha (Shia mourning poems). Frontend on Cloudflare Pages, API on Cloudflare Workers (D1 + R2).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "gen-icons": "node scripts/gen-icons.mjs",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "db:apply:local": "wrangler d1 execute noha-directory --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute noha-directory --remote --file=./schema.sql"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vite-plugin-pwa": "^0.20.5",
    "wrangler": "^3.78.0"
  }
}
